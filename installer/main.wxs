<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="MyTunnelApp"
           Manufacturer="MyTunnelApp"
           Version="0.1.0"
           Scope="perMachine"
           UpgradeCode="12345678-1234-1234-1234-1234567890AB">
    <MediaTemplate EmbedCab="yes" />
    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of [ProductName] is already installed." />

    <Property Id="EXISTING_LEGACY_CONFIG_URL" Secure="yes">
      <RegistrySearch Id="SearchLegacyConfigUrl"
                      Root="HKLM"
                      Key="SOFTWARE\MyTunnelApp"
                      Name="ConfigURL"
                      Type="raw" />
    </Property>
    <Property Id="EXISTING_SERVER_URL" Secure="yes">
      <RegistrySearch Id="SearchServerUrl"
                      Root="HKLM"
                      Key="SOFTWARE\MyTunnelApp"
                      Name="ServerUrl"
                      Type="raw" />
    </Property>
    <Property Id="SERVER_URL" Secure="yes" />
    <Property Id="EXISTING_CLIENT_UID" Secure="yes">
      <RegistrySearch Id="SearchClientUid"
                      Root="HKLM"
                      Key="SOFTWARE\MyTunnelApp"
                      Name="ClientUid"
                      Type="raw" />
    </Property>
    <Property Id="CLIENT_UID" Secure="yes" />
    <Property Id="EXISTING_ENROLLMENT_SECRET" Hidden="yes" Secure="yes">
      <RegistrySearch Id="SearchEnrollmentSecret"
                      Root="HKLM"
                      Key="SOFTWARE\MyTunnelApp"
                      Name="EnrollmentSecret"
                      Type="raw" />
    </Property>
    <Property Id="ENROLLMENT_SECRET" Hidden="yes" Secure="yes" />
    <Property Id="EXISTING_EXPECTED_DEVICE_ID" Secure="yes">
      <RegistrySearch Id="SearchExpectedDeviceId"
                      Root="HKLM"
                      Key="SOFTWARE\MyTunnelApp"
                      Name="ExpectedDeviceId"
                      Type="raw" />
    </Property>
    <Property Id="EXISTING_LEGACY_DEVICE_ID" Secure="yes">
      <RegistrySearch Id="SearchLegacyDeviceId"
                      Root="HKLM"
                      Key="SOFTWARE\MyTunnelApp"
                      Name="DeviceId"
                      Type="raw" />
    </Property>
    <Property Id="CURRENT_DEVICE_ID" Secure="yes" />
    <Property Id="EXPECTED_DEVICE_ID" Secure="yes" />
    <Property Id="PROBE_STATUS_MESSAGE" Secure="yes" />
    <Property Id="PREREG_CHECK_RESULT" Secure="yes" />
    <Property Id="PREREG_STATUS_MESSAGE" Secure="yes" />
    <Property Id="EXISTING_POLL_INTERVAL" Secure="yes">
      <RegistrySearch Id="SearchPollInterval"
                      Root="HKLM"
                      Key="SOFTWARE\MyTunnelApp"
                      Name="PollInterval"
                      Type="raw" />
    </Property>
    <Property Id="POLL_INTERVAL" Secure="yes" />
    <Property Id="EXISTING_RENEW_BEFORE" Secure="yes">
      <RegistrySearch Id="SearchRenewBefore"
                      Root="HKLM"
                      Key="SOFTWARE\MyTunnelApp"
                      Name="RenewBefore"
                      Type="raw" />
    </Property>
    <Property Id="RENEW_BEFORE" Secure="yes" />
    <Property Id="EXISTING_LOG_LEVEL" Secure="yes">
      <RegistrySearch Id="SearchLogLevel"
                      Root="HKLM"
                      Key="SOFTWARE\MyTunnelApp"
                      Name="LogLevel"
                      Type="raw" />
    </Property>
    <Property Id="LOG_LEVEL" Secure="yes" />
    <Property Id="EXISTING_ENROLLMENT_SECRET_PROTECTED" Hidden="yes" Secure="yes">
      <RegistrySearch Id="SearchProtectedEnrollmentSecret"
                      Root="HKLM"
                      Key="SOFTWARE\MyTunnelApp"
                      Name="EnrollmentSecretProtected"
                      Type="raw" />
    </Property>
    <Property Id="EXISTING_ENROLLMENT_SECRET_LEGACY" Hidden="yes" Secure="yes">
      <RegistrySearch Id="SearchLegacyEnrollmentSecret"
                      Root="HKLM"
                      Key="SOFTWARE\MyTunnelApp"
                      Name="EnrollmentSecret"
                      Type="raw" />
    </Property>
    <CustomAction Id="SetServerUrlFromExisting" Property="SERVER_URL" Value="[EXISTING_SERVER_URL]" Execute="firstSequence" />
    <CustomAction Id="SetServerUrlFromLegacy" Property="SERVER_URL" Value="[EXISTING_LEGACY_CONFIG_URL]" Execute="firstSequence" />
    <CustomAction Id="SetServerUrlDefault" Property="SERVER_URL" Value="https://example.invalid/scep" Execute="firstSequence" />
    <CustomAction Id="SetClientUidFromExisting" Property="CLIENT_UID" Value="[EXISTING_CLIENT_UID]" Execute="firstSequence" />
    <CustomAction Id="SetEnrollmentSecretFromExisting" Property="ENROLLMENT_SECRET" Value="[EXISTING_ENROLLMENT_SECRET]" Execute="firstSequence" />
    <CustomAction Id="SetExpectedDeviceIdFromExisting" Property="EXPECTED_DEVICE_ID" Value="[EXISTING_EXPECTED_DEVICE_ID]" Execute="firstSequence" />
    <CustomAction Id="SetExpectedDeviceIdFromLegacyRegistry" Property="EXPECTED_DEVICE_ID" Value="[EXISTING_LEGACY_DEVICE_ID]" Execute="firstSequence" />
    <CustomAction Id="SetPollIntervalFromExisting" Property="POLL_INTERVAL" Value="[EXISTING_POLL_INTERVAL]" Execute="firstSequence" />
    <CustomAction Id="SetPollIntervalDefault" Property="POLL_INTERVAL" Value="1h" Execute="firstSequence" />
    <CustomAction Id="SetRenewBeforeFromExisting" Property="RENEW_BEFORE" Value="[EXISTING_RENEW_BEFORE]" Execute="firstSequence" />
    <CustomAction Id="SetRenewBeforeDefault" Property="RENEW_BEFORE" Value="14d" Execute="firstSequence" />
    <CustomAction Id="SetLogLevelFromExisting" Property="LOG_LEVEL" Value="[EXISTING_LOG_LEVEL]" Execute="firstSequence" />
    <CustomAction Id="SetLogLevelDefault" Property="LOG_LEVEL" Value="info" Execute="firstSequence" />
    <CustomAction Id="SetProbeStatusDefault" Property="PROBE_STATUS_MESSAGE" Value="Reading the canonical TPM device identity from the local endorsement key." Execute="firstSequence" />
    <CustomAction Id="SetPreregStatusDefault" Property="PREREG_STATUS_MESSAGE" Value="Enter SERVER_URL and CLIENT_UID, then click Check preregistration." Execute="firstSequence" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALTEXT"
              Value="MyTunnelService is installed for machine-wide certificate enrollment and renewal. Uninstall removes installer-managed configuration but intentionally leaves issued certificates and TPM-backed keys in place." />
    <Binary Id="DeviceIdentityPreregScript"
            SourceFile="device_identity_prereg.vbs" />
    <CustomAction Id="RunProbeCurrentDeviceIdentityUI"
                  BinaryRef="DeviceIdentityPreregScript"
                  VBScriptCall="ProbeCurrentDeviceIdentity"
                  Execute="immediate"
                  Return="check" />
    <CustomAction Id="RunCheckPreregistrationUI"
                  BinaryRef="DeviceIdentityPreregScript"
                  VBScriptCall="CheckPreregistration"
                  Execute="immediate"
                  Return="check" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <UIRef Id="WixUI_ErrorProgressText" />
    <SetDirectory Id="INSTALLFOLDER" Value="[ProgramFiles64Folder]MyTunnelApp" />

    <Launch Condition="REMOVE=&quot;ALL&quot; OR UILevel &gt;= 5 OR (SERVER_URL AND SERVER_URL &lt;&gt; &quot;https://example.invalid/scep&quot; AND SERVER_URL &gt;&lt; &quot;://&quot;)" Message="SERVER_URL must point to the SCEP endpoint and cannot use the example.invalid placeholder." />
    <Launch Condition="REMOVE=&quot;ALL&quot; OR UILevel &gt;= 5 OR CLIENT_UID" Message="CLIENT_UID must be specified." />
    <Launch Condition="REMOVE=&quot;ALL&quot; OR UILevel &gt;= 5 OR ENROLLMENT_SECRET OR Installed OR (EXISTING_SERVER_URL AND EXISTING_CLIENT_UID AND EXISTING_EXPECTED_DEVICE_ID)" Message="ENROLLMENT_SECRET must be specified for new installs. Repairs, upgrades, and same-version reinstalls may leave it blank when the machine is already configured." />
    <Launch Condition="REMOVE=&quot;ALL&quot; OR UILevel &gt;= 5 OR EXPECTED_DEVICE_ID" Message="EXPECTED_DEVICE_ID must be specified. The GUI MSI probes the canonical TPM device identity on page 1 before preregistration." />
    <Launch Condition="REMOVE=&quot;ALL&quot; OR UILevel &gt;= 5 OR NOT LOG_LEVEL OR LOG_LEVEL = &quot;trace&quot; OR LOG_LEVEL = &quot;debug&quot; OR LOG_LEVEL = &quot;info&quot; OR LOG_LEVEL = &quot;warn&quot; OR LOG_LEVEL = &quot;error&quot;" Message="LOG_LEVEL must be one of trace, debug, info, warn, or error." />

    <InstallUISequence>
      <Custom Action="SetServerUrlFromExisting" After="AppSearch" Condition="NOT SERVER_URL AND EXISTING_SERVER_URL" />
      <Custom Action="SetServerUrlFromLegacy" After="SetServerUrlFromExisting" Condition="NOT SERVER_URL AND EXISTING_LEGACY_CONFIG_URL" />
      <Custom Action="SetServerUrlDefault" After="SetServerUrlFromLegacy" Condition="NOT SERVER_URL" />
      <Custom Action="SetClientUidFromExisting" After="SetServerUrlDefault" Condition="NOT CLIENT_UID AND EXISTING_CLIENT_UID" />
      <Custom Action="SetEnrollmentSecretFromExisting" After="SetClientUidFromExisting" Condition="NOT ENROLLMENT_SECRET AND EXISTING_ENROLLMENT_SECRET" />
      <Custom Action="SetExpectedDeviceIdFromExisting" After="SetEnrollmentSecretFromExisting" Condition="NOT EXPECTED_DEVICE_ID AND EXISTING_EXPECTED_DEVICE_ID" />
      <Custom Action="SetExpectedDeviceIdFromLegacyRegistry" After="SetExpectedDeviceIdFromExisting" Condition="NOT EXPECTED_DEVICE_ID AND EXISTING_LEGACY_DEVICE_ID" />
      <Custom Action="SetPollIntervalFromExisting" After="SetExpectedDeviceIdFromLegacyRegistry" Condition="NOT POLL_INTERVAL AND EXISTING_POLL_INTERVAL" />
      <Custom Action="SetPollIntervalDefault" After="SetPollIntervalFromExisting" Condition="NOT POLL_INTERVAL" />
      <Custom Action="SetRenewBeforeFromExisting" After="SetPollIntervalDefault" Condition="NOT RENEW_BEFORE AND EXISTING_RENEW_BEFORE" />
      <Custom Action="SetRenewBeforeDefault" After="SetRenewBeforeFromExisting" Condition="NOT RENEW_BEFORE" />
      <Custom Action="SetLogLevelFromExisting" After="SetRenewBeforeDefault" Condition="NOT LOG_LEVEL AND EXISTING_LOG_LEVEL" />
      <Custom Action="SetLogLevelDefault" After="SetLogLevelFromExisting" Condition="NOT LOG_LEVEL" />
      <Custom Action="SetProbeStatusDefault" After="SetLogLevelDefault" Condition="NOT PROBE_STATUS_MESSAGE" />
      <Custom Action="SetPreregStatusDefault" After="SetProbeStatusDefault" Condition="NOT PREREG_STATUS_MESSAGE" />
      <Custom Action="RunProbeCurrentDeviceIdentityUI" After="SetPreregStatusDefault" Condition="NOT REMOVE=&quot;ALL&quot;" />
    </InstallUISequence>

    <InstallExecuteSequence>
      <Custom Action="SetServerUrlFromExisting" After="AppSearch" Condition="NOT SERVER_URL AND EXISTING_SERVER_URL" />
      <Custom Action="SetServerUrlFromLegacy" After="SetServerUrlFromExisting" Condition="NOT SERVER_URL AND EXISTING_LEGACY_CONFIG_URL" />
      <Custom Action="SetServerUrlDefault" After="SetServerUrlFromLegacy" Condition="NOT SERVER_URL" />
      <Custom Action="SetClientUidFromExisting" After="SetServerUrlDefault" Condition="NOT CLIENT_UID AND EXISTING_CLIENT_UID" />
      <Custom Action="SetEnrollmentSecretFromExisting" After="SetClientUidFromExisting" Condition="NOT ENROLLMENT_SECRET AND EXISTING_ENROLLMENT_SECRET" />
      <Custom Action="SetExpectedDeviceIdFromExisting" After="SetEnrollmentSecretFromExisting" Condition="NOT EXPECTED_DEVICE_ID AND EXISTING_EXPECTED_DEVICE_ID" />
      <Custom Action="SetExpectedDeviceIdFromLegacyRegistry" After="SetExpectedDeviceIdFromExisting" Condition="NOT EXPECTED_DEVICE_ID AND EXISTING_LEGACY_DEVICE_ID" />
      <Custom Action="SetPollIntervalFromExisting" After="SetExpectedDeviceIdFromLegacyRegistry" Condition="NOT POLL_INTERVAL AND EXISTING_POLL_INTERVAL" />
      <Custom Action="SetPollIntervalDefault" After="SetPollIntervalFromExisting" Condition="NOT POLL_INTERVAL" />
      <Custom Action="SetRenewBeforeFromExisting" After="SetPollIntervalDefault" Condition="NOT RENEW_BEFORE AND EXISTING_RENEW_BEFORE" />
      <Custom Action="SetRenewBeforeDefault" After="SetRenewBeforeFromExisting" Condition="NOT RENEW_BEFORE" />
      <Custom Action="SetLogLevelFromExisting" After="SetRenewBeforeDefault" Condition="NOT LOG_LEVEL AND EXISTING_LOG_LEVEL" />
      <Custom Action="SetLogLevelDefault" After="SetLogLevelFromExisting" Condition="NOT LOG_LEVEL" />
    </InstallExecuteSequence>

    <UI>
      <!-- Skip the stock WixUI license page; this installer has no EULA to present. -->
      <Publish Dialog="WelcomeDlg"
               Control="Next"
               Event="NewDialog"
               Value="InstallDirDlg"
               Condition="NOT Installed"
               Order="2" />
      <Publish Dialog="InstallDirDlg"
               Control="Back"
               Event="NewDialog"
               Value="WelcomeDlg"
               Order="2" />

      <!-- Keep the standard WixUI flow for directory selection, then collect SCEP values just before ExecuteAction. -->
      <Dialog Id="DeviceIdentityDlg" Width="370" Height="270" Title="[ProductName] device identity">
        <Control Id="IntroTitle"
                 Type="Text"
                 X="20"
                 Y="15"
                 Width="330"
                 Height="18"
                 NoPrefix="yes"
                 Text="Step 1: probe the canonical TPM device identity" />
        <Control Id="IntroText"
                 Type="Text"
                 X="20"
                 Y="35"
                 Width="330"
                 Height="40"
                 NoPrefix="yes"
                 Text="This page reads the Windows TPM endorsement key and derives the canonical device identity for preregistration. Copy CURRENT_DEVICE_ID, register it on the server, then continue." />
        <Control Id="CurrentDeviceIdLabel"
                 Type="Text"
                 X="20"
                 Y="92"
                 Width="120"
                 Height="15"
                 Text="CURRENT_DEVICE_ID" />
        <Control Id="CurrentDeviceIdEdit"
                 Type="Edit"
                 X="20"
                 Y="110"
                 Width="330"
                 Height="18"
                 Property="CURRENT_DEVICE_ID" />
        <Control Id="ProbeStatusText"
                 Type="Text"
                 X="20"
                 Y="142"
                 Width="330"
                 Height="58"
                 NoPrefix="yes"
                 Text="[PROBE_STATUS_MESSAGE]" />
        <Control Id="RetryProbe"
                 Type="PushButton"
                 X="20"
                 Y="240"
                 Width="80"
                 Height="17"
                 Text="Retry probe">
          <Publish Event="DoAction" Value="RunProbeCurrentDeviceIdentityUI" Condition="1" />
        </Control>
        <Control Id="Next"
                 Type="PushButton"
                 X="240"
                 Y="240"
                 Width="56"
                 Height="17"
                 Default="yes"
                 Text="Next">
          <Publish Event="DoAction" Value="RunProbeCurrentDeviceIdentityUI" Order="1" Condition="1" />
          <Publish Event="SpawnDialog" Value="MissingProbeDlg" Order="2" Condition="NOT CURRENT_DEVICE_ID" />
          <Publish Event="NewDialog" Value="PreregCheckDlg" Order="10" Condition="CURRENT_DEVICE_ID" />
        </Control>
        <Control Id="Cancel"
                 Type="PushButton"
                 X="304"
                 Y="240"
                 Width="56"
                 Height="17"
                 Cancel="yes"
                 Text="Cancel">
          <Publish Event="EndDialog" Value="Exit" Condition="1" />
        </Control>
      </Dialog>

      <Dialog Id="PreregCheckDlg" Width="370" Height="270" Title="[ProductName] preregistration check">
        <Control Id="IntroTitle"
                 Type="Text"
                 X="20"
                 Y="15"
                 Width="330"
                 Height="18"
                 NoPrefix="yes"
                 Text="Step 2: confirm preregistration readiness" />
        <Control Id="IntroText"
                 Type="Text"
                 X="20"
                 Y="35"
                 Width="330"
                 Height="32"
                 NoPrefix="yes"
                 Text="Enter SERVER_URL and opaque CLIENT_UID, then ask the server whether this machine is preregistered and ready for the initial enrollment secret." />
        <Control Id="ServerUrlLabel"
                 Type="Text"
                 X="20"
                 Y="82"
                 Width="110"
                 Height="15"
                 Text="SERVER_URL" />
        <Control Id="ServerUrlEdit"
                 Type="Edit"
                 X="140"
                 Y="80"
                 Width="210"
                 Height="18"
                 Property="SERVER_URL" />
        <Control Id="ClientUidLabel"
                 Type="Text"
                 X="20"
                 Y="112"
                 Width="110"
                 Height="15"
                 Text="CLIENT_UID" />
        <Control Id="ClientUidEdit"
                 Type="Edit"
                 X="140"
                 Y="110"
                 Width="210"
                 Height="18"
                 Property="CLIENT_UID" />
        <Control Id="CurrentDeviceIdLabel"
                 Type="Text"
                 X="20"
                 Y="142"
                 Width="110"
                 Height="15"
                 Text="CURRENT_DEVICE_ID" />
        <Control Id="CurrentDeviceIdEdit"
                 Type="Edit"
                 X="140"
                 Y="140"
                 Width="210"
                 Height="18"
                 Property="CURRENT_DEVICE_ID" />
        <Control Id="PreregStatusText"
                 Type="Text"
                 X="20"
                 Y="170"
                 Width="330"
                 Height="42"
                 NoPrefix="yes"
                 Text="[PREREG_STATUS_MESSAGE]" />
        <Control Id="Check"
                 Type="PushButton"
                 X="20"
                 Y="240"
                 Width="80"
                 Height="17"
                 Text="Check">
          <Publish Event="DoAction" Value="RunCheckPreregistrationUI" Condition="1" />
        </Control>
        <Control Id="Back"
                 Type="PushButton"
                 X="180"
                 Y="240"
                 Width="56"
                 Height="17"
                 Text="Back">
          <Publish Event="NewDialog" Value="DeviceIdentityDlg" Condition="1" />
        </Control>
        <Control Id="Next"
                 Type="PushButton"
                 X="240"
                 Y="240"
                 Width="56"
                 Height="17"
                 Default="yes"
                 Text="Next">
          <Publish Event="DoAction" Value="RunCheckPreregistrationUI" Order="1" Condition="1" />
          <Publish Event="SpawnDialog" Value="ServerUrlPlaceholderDlg" Order="2" Condition="SERVER_URL = &quot;https://example.invalid/scep&quot;" />
          <Publish Event="SpawnDialog" Value="ServerUrlFormatDlg" Order="3" Condition="SERVER_URL AND NOT (SERVER_URL &gt;&lt; &quot;://&quot;)" />
          <Publish Event="SpawnDialog" Value="MissingProbeDlg" Order="4" Condition="NOT CURRENT_DEVICE_ID" />
          <Publish Event="SpawnDialog" Value="MissingPreregValuesDlg" Order="5" Condition="NOT SERVER_URL OR NOT CLIENT_UID" />
          <Publish Event="SpawnDialog" Value="PreregCheckNotReadyDlg" Order="6" Condition="SERVER_URL AND CLIENT_UID AND CURRENT_DEVICE_ID AND PREREG_CHECK_RESULT &lt;&gt; &quot;ready&quot;" />
          <Publish Event="NewDialog" Value="ScepConfigDlg" Order="10" Condition="SERVER_URL AND SERVER_URL &lt;&gt; &quot;https://example.invalid/scep&quot; AND SERVER_URL &gt;&lt; &quot;://&quot; AND CLIENT_UID AND CURRENT_DEVICE_ID AND PREREG_CHECK_RESULT = &quot;ready&quot;" />
        </Control>
        <Control Id="Cancel"
                 Type="PushButton"
                 X="304"
                 Y="240"
                 Width="56"
                 Height="17"
                 Cancel="yes"
                 Text="Cancel">
          <Publish Event="EndDialog" Value="Exit" Condition="1" />
        </Control>
      </Dialog>

      <Dialog Id="ScepConfigDlg" Width="370" Height="270" Title="[ProductName] enrollment secret">
        <Control Id="IntroTitle"
                 Type="Text"
                 X="20"
                 Y="15"
                 Width="330"
                 Height="18"
                 NoPrefix="yes"
                 Text="Step 3: enter the initial enrollment secret" />
        <Control Id="IntroText"
                 Type="Text"
                 X="20"
                 Y="35"
                 Width="330"
                 Height="32"
                 NoPrefix="yes"
                 Text="Preregistration is ready. Enter the one-time ENROLLMENT_SECRET issued after preregistration. Existing configured machines may leave it blank for repair, upgrade, or same-version reinstall." />
        <Control Id="ServerUrlSummary"
                 Type="Text"
                 X="20"
                 Y="82"
                 Width="330"
                 Height="15"
                 NoPrefix="yes"
                 Text="SERVER_URL: [SERVER_URL]" />
        <Control Id="ClientUidSummary"
                 Type="Text"
                 X="20"
                 Y="102"
                 Width="330"
                 Height="15"
                 NoPrefix="yes"
                 Text="CLIENT_UID: [CLIENT_UID]" />
        <Control Id="EnrollmentSecretLabel"
                 Type="Text"
                 X="20"
                 Y="132"
                 Width="110"
                 Height="15"
                 Text="ENROLLMENT_SECRET" />
        <Control Id="EnrollmentSecretEdit"
                 Type="Edit"
                 X="140"
                 Y="130"
                 Width="210"
                 Height="18"
                 Property="ENROLLMENT_SECRET"
                 Password="yes" />
        <Control Id="SecretHint"
                 Type="Text"
                 X="20"
                 Y="158"
                 Width="330"
                 Height="40"
                 NoPrefix="yes"
                 Text="Leave ENROLLMENT_SECRET blank only during repair, upgrade, or same-version reinstall of an already configured machine. Successful initial issuance removes the bootstrap secret from Windows afterward. EXPECTED_DEVICE_ID is fixed from the probed TPM identity and no longer accepts manual overrides in release builds." />
        <Control Id="Advanced"
                 Type="PushButton"
                 X="20"
                 Y="240"
                 Width="80"
                 Height="17"
                 Text="Advanced...">
          <Publish Event="NewDialog" Value="ScepAdvancedDlg" Condition="1" />
        </Control>
        <Control Id="Back"
                 Type="PushButton"
                 X="180"
                 Y="240"
                 Width="56"
                 Height="17"
                 Text="Back">
          <Publish Event="NewDialog" Value="PreregCheckDlg" Condition="1" />
        </Control>
        <Control Id="Install"
                 Type="PushButton"
                 X="240"
                 Y="240"
                 Width="56"
                 Height="17"
                 Default="yes"
                 Text="Install">
          <Publish Event="SpawnDialog" Value="ServerUrlPlaceholderDlg" Order="1" Condition="SERVER_URL = &quot;https://example.invalid/scep&quot;" />
          <Publish Event="SpawnDialog" Value="ServerUrlFormatDlg" Order="2" Condition="SERVER_URL AND NOT (SERVER_URL &gt;&lt; &quot;://&quot;)" />
          <Publish Event="SpawnDialog" Value="MissingProbeDlg" Order="3" Condition="NOT CURRENT_DEVICE_ID OR NOT EXPECTED_DEVICE_ID" />
          <Publish Event="SpawnDialog" Value="MissingPreregValuesDlg" Order="4" Condition="NOT SERVER_URL OR NOT CLIENT_UID" />
          <Publish Event="SpawnDialog" Value="PreregCheckNotReadyDlg" Order="5" Condition="SERVER_URL AND CLIENT_UID AND CURRENT_DEVICE_ID AND EXPECTED_DEVICE_ID AND PREREG_CHECK_RESULT &lt;&gt; &quot;ready&quot;" />
          <Publish Event="SpawnDialog" Value="MissingEnrollmentSecretDlg" Order="6" Condition="SERVER_URL AND CLIENT_UID AND CURRENT_DEVICE_ID AND EXPECTED_DEVICE_ID AND PREREG_CHECK_RESULT = &quot;ready&quot; AND NOT ENROLLMENT_SECRET AND NOT (Installed OR (EXISTING_SERVER_URL AND EXISTING_CLIENT_UID AND EXISTING_EXPECTED_DEVICE_ID))" />
          <Publish Event="EndDialog" Value="Return" Order="10" Condition="SERVER_URL AND SERVER_URL &lt;&gt; &quot;https://example.invalid/scep&quot; AND SERVER_URL &gt;&lt; &quot;://&quot; AND CLIENT_UID AND CURRENT_DEVICE_ID AND EXPECTED_DEVICE_ID AND PREREG_CHECK_RESULT = &quot;ready&quot; AND (ENROLLMENT_SECRET OR Installed OR (EXISTING_SERVER_URL AND EXISTING_CLIENT_UID AND EXISTING_EXPECTED_DEVICE_ID))" />
        </Control>
        <Control Id="Cancel"
                 Type="PushButton"
                 X="304"
                 Y="240"
                 Width="56"
                 Height="17"
                 Cancel="yes"
                 Text="Cancel">
          <Publish Event="EndDialog" Value="Exit" Condition="1" />
        </Control>
      </Dialog>

      <Dialog Id="ScepAdvancedDlg" Width="370" Height="270" Title="[ProductName] advanced settings">
        <Control Id="AdvancedIntro"
                 Type="Text"
                 X="20"
                 Y="15"
                 Width="330"
                 Height="18"
                 NoPrefix="yes"
                 Text="Advanced settings (optional)" />
        <Control Id="AdvancedText"
                 Type="Text"
                 X="20"
                 Y="35"
                 Width="330"
                 Height="30"
                 NoPrefix="yes"
                 Text="EXPECTED_DEVICE_ID is fixed from the probed TPM identity and confirmed by preregistration. Only timing and logging knobs remain editable here." />
        <Control Id="ExpectedDeviceIdLabel"
                 Type="Text"
                 X="20"
                 Y="82"
                 Width="110"
                 Height="15"
                 Text="EXPECTED_DEVICE_ID" />
        <Control Id="ExpectedDeviceIdValue"
                 Type="Text"
                 X="140"
                 Y="82"
                 Width="210"
                 Height="18"
                 NoPrefix="yes"
                 Text="[EXPECTED_DEVICE_ID]" />
        <Control Id="PollIntervalLabel"
                 Type="Text"
                 X="20"
                 Y="112"
                 Width="110"
                 Height="15"
                 Text="POLL_INTERVAL" />
        <Control Id="PollIntervalEdit"
                 Type="Edit"
                 X="140"
                 Y="110"
                 Width="210"
                 Height="18"
                 Property="POLL_INTERVAL" />
        <Control Id="RenewBeforeLabel"
                 Type="Text"
                 X="20"
                 Y="142"
                 Width="110"
                 Height="15"
                 Text="RENEW_BEFORE" />
        <Control Id="RenewBeforeEdit"
                 Type="Edit"
                 X="140"
                 Y="140"
                 Width="210"
                 Height="18"
                 Property="RENEW_BEFORE" />
        <Control Id="LogLevelLabel"
                 Type="Text"
                 X="20"
                 Y="172"
                 Width="110"
                 Height="15"
                 Text="LOG_LEVEL" />
        <Control Id="LogLevelEdit"
                 Type="Edit"
                 X="140"
                 Y="170"
                 Width="210"
                 Height="18"
                 Property="LOG_LEVEL" />
        <Control Id="LogLevelHint"
                 Type="Text"
                 X="20"
                 Y="196"
                 Width="330"
                 Height="26"
                 NoPrefix="yes"
                 Text="LOG_LEVEL must be trace, debug, info, warn, or error. Duration values accept raw seconds or s/m/h/d suffixes, for example 300, 30m, 1h, or 14d." />
        <Control Id="Back"
                 Type="PushButton"
                 X="180"
                 Y="240"
                 Width="56"
                 Height="17"
                 Text="Back">
          <Publish Event="NewDialog" Value="ScepConfigDlg" Condition="1" />
        </Control>
        <Control Id="Install"
                 Type="PushButton"
                 X="240"
                 Y="240"
                 Width="56"
                 Height="17"
                 Default="yes"
                 Text="Install">
          <Publish Event="SpawnDialog" Value="ServerUrlPlaceholderDlg" Order="1" Condition="SERVER_URL = &quot;https://example.invalid/scep&quot;" />
          <Publish Event="SpawnDialog" Value="ServerUrlFormatDlg" Order="2" Condition="SERVER_URL AND NOT (SERVER_URL &gt;&lt; &quot;://&quot;)" />
          <Publish Event="SpawnDialog" Value="MissingProbeDlg" Order="3" Condition="NOT CURRENT_DEVICE_ID OR NOT EXPECTED_DEVICE_ID" />
          <Publish Event="SpawnDialog" Value="MissingPreregValuesDlg" Order="4" Condition="NOT SERVER_URL OR NOT CLIENT_UID" />
          <Publish Event="SpawnDialog" Value="PreregCheckNotReadyDlg" Order="5" Condition="SERVER_URL AND CLIENT_UID AND CURRENT_DEVICE_ID AND EXPECTED_DEVICE_ID AND PREREG_CHECK_RESULT &lt;&gt; &quot;ready&quot;" />
          <Publish Event="SpawnDialog" Value="MissingEnrollmentSecretDlg" Order="6" Condition="SERVER_URL AND CLIENT_UID AND CURRENT_DEVICE_ID AND EXPECTED_DEVICE_ID AND PREREG_CHECK_RESULT = &quot;ready&quot; AND NOT ENROLLMENT_SECRET AND NOT (Installed OR (EXISTING_SERVER_URL AND EXISTING_CLIENT_UID AND EXISTING_EXPECTED_DEVICE_ID))" />
          <Publish Event="SpawnDialog" Value="InvalidLogLevelDlg" Order="7" Condition="SERVER_URL AND CLIENT_UID AND CURRENT_DEVICE_ID AND EXPECTED_DEVICE_ID AND PREREG_CHECK_RESULT = &quot;ready&quot; AND LOG_LEVEL AND LOG_LEVEL &lt;&gt; &quot;trace&quot; AND LOG_LEVEL &lt;&gt; &quot;debug&quot; AND LOG_LEVEL &lt;&gt; &quot;info&quot; AND LOG_LEVEL &lt;&gt; &quot;warn&quot; AND LOG_LEVEL &lt;&gt; &quot;error&quot;" />
          <Publish Event="EndDialog" Value="Return" Order="10" Condition="SERVER_URL AND SERVER_URL &lt;&gt; &quot;https://example.invalid/scep&quot; AND SERVER_URL &gt;&lt; &quot;://&quot; AND CLIENT_UID AND CURRENT_DEVICE_ID AND EXPECTED_DEVICE_ID AND PREREG_CHECK_RESULT = &quot;ready&quot; AND (ENROLLMENT_SECRET OR Installed OR (EXISTING_SERVER_URL AND EXISTING_CLIENT_UID AND EXISTING_EXPECTED_DEVICE_ID)) AND (NOT LOG_LEVEL OR LOG_LEVEL = &quot;trace&quot; OR LOG_LEVEL = &quot;debug&quot; OR LOG_LEVEL = &quot;info&quot; OR LOG_LEVEL = &quot;warn&quot; OR LOG_LEVEL = &quot;error&quot;)" />
        </Control>
        <Control Id="Cancel"
                 Type="PushButton"
                 X="304"
                 Y="240"
                 Width="56"
                 Height="17"
                 Cancel="yes"
                 Text="Cancel">
          <Publish Event="EndDialog" Value="Exit" Condition="1" />
        </Control>
      </Dialog>

      <Dialog Id="MissingProbeDlg" Width="260" Height="95" Title="[ProductName] validation">
        <Control Id="Message"
                 Type="Text"
                 X="20"
                 Y="18"
                 Width="220"
                 Height="34"
                 NoPrefix="yes"
                 Text="[PROBE_STATUS_MESSAGE]" />
        <Control Id="Ok"
                 Type="PushButton"
                 X="102"
                 Y="60"
                 Width="56"
                 Height="17"
                 Default="yes"
                 Cancel="yes"
                 Text="OK">
          <Publish Event="EndDialog" Value="Return" Condition="1" />
        </Control>
      </Dialog>

      <Dialog Id="MissingPreregValuesDlg" Width="260" Height="95" Title="[ProductName] validation">
        <Control Id="Message"
                 Type="Text"
                 X="20"
                 Y="18"
                 Width="220"
                 Height="30"
                 NoPrefix="yes"
                 Text="SERVER_URL and CLIENT_UID are required before the preregistration check can run." />
        <Control Id="Ok"
                 Type="PushButton"
                 X="102"
                 Y="60"
                 Width="56"
                 Height="17"
                 Default="yes"
                 Cancel="yes"
                 Text="OK">
          <Publish Event="EndDialog" Value="Return" Condition="1" />
        </Control>
      </Dialog>

      <Dialog Id="MissingEnrollmentSecretDlg" Width="260" Height="95" Title="[ProductName] validation">
        <Control Id="Message"
                 Type="Text"
                 X="20"
                 Y="18"
                 Width="220"
                 Height="30"
                 NoPrefix="yes"
                 Text="ENROLLMENT_SECRET is required for new installs. Repairs, upgrades, and same-version reinstalls may leave it blank when the machine is already configured." />
        <Control Id="Ok"
                 Type="PushButton"
                 X="102"
                 Y="60"
                 Width="56"
                 Height="17"
                 Default="yes"
                 Cancel="yes"
                 Text="OK">
          <Publish Event="EndDialog" Value="Return" Condition="1" />
        </Control>
      </Dialog>

      <Dialog Id="PreregCheckNotReadyDlg" Width="260" Height="95" Title="[ProductName] validation">
        <Control Id="Message"
                 Type="Text"
                 X="20"
                 Y="18"
                 Width="220"
                 Height="34"
                 NoPrefix="yes"
                 Text="[PREREG_STATUS_MESSAGE]" />
        <Control Id="Ok"
                 Type="PushButton"
                 X="102"
                 Y="60"
                 Width="56"
                 Height="17"
                 Default="yes"
                 Cancel="yes"
                 Text="OK">
          <Publish Event="EndDialog" Value="Return" Condition="1" />
        </Control>
      </Dialog>

      <Dialog Id="ServerUrlPlaceholderDlg" Width="260" Height="95" Title="[ProductName] validation">
        <Control Id="Message"
                 Type="Text"
                 X="20"
                 Y="18"
                 Width="220"
                 Height="30"
                 NoPrefix="yes"
                 Text="Replace the example.invalid placeholder with the actual SCEP endpoint URL." />
        <Control Id="Ok"
                 Type="PushButton"
                 X="102"
                 Y="60"
                 Width="56"
                 Height="17"
                 Default="yes"
                 Cancel="yes"
                 Text="OK">
          <Publish Event="EndDialog" Value="Return" Condition="1" />
        </Control>
      </Dialog>

      <Dialog Id="ServerUrlFormatDlg" Width="260" Height="95" Title="[ProductName] validation">
        <Control Id="Message"
                 Type="Text"
                 X="20"
                 Y="18"
                 Width="220"
                 Height="30"
                 NoPrefix="yes"
                 Text="SERVER_URL must include a scheme, for example https://scep.example.com/scep." />
        <Control Id="Ok"
                 Type="PushButton"
                 X="102"
                 Y="60"
                 Width="56"
                 Height="17"
                 Default="yes"
                 Cancel="yes"
                 Text="OK">
          <Publish Event="EndDialog" Value="Return" Condition="1" />
        </Control>
      </Dialog>

      <Dialog Id="InvalidLogLevelDlg" Width="260" Height="95" Title="[ProductName] validation">
        <Control Id="Message"
                 Type="Text"
                 X="20"
                 Y="18"
                 Width="220"
                 Height="30"
                 NoPrefix="yes"
                 Text="LOG_LEVEL must be trace, debug, info, warn, or error." />
        <Control Id="Ok"
                 Type="PushButton"
                 X="102"
                 Y="60"
                 Width="56"
                 Height="17"
                 Default="yes"
                 Cancel="yes"
                 Text="OK">
          <Publish Event="EndDialog" Value="Return" Condition="1" />
        </Control>
      </Dialog>
    </UI>

    <InstallUISequence>
      <Show Dialog="DeviceIdentityDlg" Before="ExecuteAction" Condition="NOT REMOVE=&quot;ALL&quot;" />
    </InstallUISequence>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER">
        <Component Id="ConfigComponent" Guid="*" Bitness="always64">
          <RegistryKey Root="HKLM" Key="SOFTWARE\MyTunnelApp" ForceCreateOnInstall="yes">
            <Permission Domain="NT AUTHORITY"
                        User="LocalService"
                        Read="yes"
                        Write="yes"
                        CreateSubkeys="yes"
                        Delete="yes"
                        EnumerateSubkeys="yes" />
            <RegistryValue Name="ConfigURL"
                           Type="string"
                           Value="[SERVER_URL]" />
            <RegistryValue Name="ServerUrl"
                           Type="string"
                           Value="[SERVER_URL]"
                           KeyPath="yes" />
            <RegistryValue Name="ClientUid"
                           Type="string"
                           Value="[CLIENT_UID]" />
            <!-- This WiX-only phase still stages the bootstrap secret as a registry value when it is supplied.
                 Successful initial issuance removes both EnrollmentSecret and EnrollmentSecretProtected afterward. -->
            <RegistryValue Name="EnrollmentSecret"
                           Type="string"
                           Value="[ENROLLMENT_SECRET]" />
            <RegistryValue Name="ExpectedDeviceId"
                           Type="string"
                           Value="[EXPECTED_DEVICE_ID]" />
            <RegistryValue Name="DeviceId"
                           Type="string"
                           Value="[EXPECTED_DEVICE_ID]" />
            <RegistryValue Name="PollInterval"
                           Type="string"
                           Value="[POLL_INTERVAL]" />
            <RegistryValue Name="RenewBefore"
                           Type="string"
                           Value="[RENEW_BEFORE]" />
            <RegistryValue Name="LogLevel"
                           Type="string"
                           Value="[LOG_LEVEL]" />
          </RegistryKey>
          <RemoveRegistryKey Root="HKLM"
                             Key="SOFTWARE\MyTunnelApp"
                             Action="removeOnUninstall" />
        </Component>
        <Component Id="ServiceComponent" Guid="*" Bitness="always64">
          <File Id="ServiceExe"
                Source="../rust-client/target/release/service.exe"
                KeyPath="yes" />
          <ServiceInstall Id="ServiceInstaller"
                          Type="ownProcess"
                          Name="MyTunnelService"
                          DisplayName="MyTunnel Service"
                          Description="Obtains and renews client certificates."
                          Start="auto"
                          ErrorControl="normal"
                          Account="LocalSystem" />
          <ServiceControl Id="ServiceController"
                          Name="MyTunnelService"
                          Start="install"
                          Stop="both"
                          Remove="uninstall"
                          Wait="yes" />
        </Component>
        <Component Id="ScepClientComponent" Guid="*" Bitness="always64">
          <File Id="ScepClientExe"
                Source="../cmd/scepclient/scepclient.exe"
                KeyPath="yes" />
        </Component>
        <Component Id="DeviceIdProbeComponent" Guid="*" Bitness="always64">
          <File Id="DeviceIdProbeExe"
                Source="../cmd/scepclient/device-id-probe.exe"
                KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="MyTunnelApp" Level="1">
      <ComponentRef Id="ConfigComponent" />
      <ComponentRef Id="ServiceComponent" />
      <ComponentRef Id="ScepClientComponent" />
      <ComponentRef Id="DeviceIdProbeComponent" />
    </Feature>
  </Package>
</Wix>
