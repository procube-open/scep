{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyTunnelApp",
  "version": "0.1.0",
  "identifier": "com.mytunnel.app",
  "build": {},
  "app": {
    "windows": []
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "windows": {
      "signCommand": {
        "cmd": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "./sign-windows-artifact.ps1",
          "%1"
        ]
      }
    }
  }
}
